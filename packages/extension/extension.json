{
  "id": "builtin.font-preview",
  "name": "Font Preview",
  "description": "Font Preview",
  "browser": "dist/fontPreviewMain.js",
  "activation": ["onWebView:builtin.font-preview"],
  "languages": [],
  "rpc": [
    {
      "id": "builtin.font-preview.font-preview-worker",
      "type": "web-worker",
      "name": "Font Preview Worker",
      "url": "../font-preview-worker/dist/fontPreviewWorkerMain.js",
      "contentSecurityPolicy": ["default-src 'none'"]
    }
  ],
  "webViews": [
    {
      "id": "builtin.font-preview",
      "rpc": "builtin.font-preview.font-preview-worker",
      "selector": [".ttf", ".woff2"],
      "contentSecurityPolicy": ["default-src 'none'", "script-src 'self'", "style-src 'self'", "img-src 'self' blob:"],
      "elements": [
        {
          "type": "title",
          "value": "Font Preview"
        },
        {
          "type": "script",
          "path": "media/index.js"
        },
        {
          "type": "css",
          "path": "media/index.css"
        }
      ]
    }
  ]
}
